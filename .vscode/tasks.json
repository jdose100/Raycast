{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "run",
            "type": "shell",
            "presentation": {
                "reveal": "always"
            },
            "isBuildCommand": false,
            "command": "${workspaceFolder}/build/main",
            "dependsOn": [
                "build"
            ],
            "problemMatcher": []
        },
        {
            "label": "build",
            "group": "build",
            "type": "shell",
            "presentation": {
                "reveal": "always"
            },
            "windows": {
                "command": "cmake",
                "args": [
                    "--build",
                    "build/"
                ]
            },
            "command": "nix-shell",
            "args": [
                "--run",
                "'cmake --build build/'"
            ]
        }
    ]
}


